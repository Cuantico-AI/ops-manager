# ops-manager production environment
# Rendered by scripts/scaffold-env.sh into /opt/ops-manager/.env (0600 root:root). Never commit the rendered .env.

# --- Node / app ---
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
APP_VERSION=0.1.0

# --- Postgres passwords (REQUIRED; docker-compose substitutes these) ---
# Rendered from: openssl rand -base64 32, mapped to base64url so they stay URL-safe
# inside the postgres:// strings docker-compose builds from them.
POSTGRES_ADMIN_PASSWORD=__GEN_POSTGRES_ADMIN_PASSWORD__
POSTGRES_APP_PASSWORD=__GEN_POSTGRES_APP_PASSWORD__
# DATABASE_URL / DATABASE_ADMIN_URL are intentionally NOT set here:
# docker-compose builds them from the two passwords above and injects them.

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- LiteLLM ---
LITELLM_PROXY_URL=http://litellm:4000
LITELLM_MASTER_KEY=__GEN_LITELLM_MASTER_KEY__
# PLACEHOLDER: real Anthropic API key (LiteLLM uses it to call Anthropic).
ANTHROPIC_API_KEY=REPLACE_ME_ANTHROPIC_API_KEY

# --- Slack (Socket Mode) ---
SLACK_BOT_TOKEN=REPLACE_ME_SLACK_BOT_TOKEN
SLACK_SIGNING_SECRET=REPLACE_ME_SLACK_SIGNING_SECRET
SLACK_APP_TOKEN=REPLACE_ME_SLACK_APP_TOKEN
SLACK_ALERTS_CHANNEL=#ops-manager-alerts

# --- Approval gate ---
# Approval gate (Phase 4)
# Production: omit BYPASS_APPROVAL entirely
# Dev only:
BYPASS_APPROVAL=true
# SLACK_APPROVALS_CHANNEL=#ops-manager-approvals
# APPROVAL_EXPIRY_HOURS=4

# Phase 2 — encrypted Postgres secrets store (generate for prod; never commit)
# SECRETS_MASTER_KEY=
# GOOGLE_SHEET_ROSTER_SPREADSHEET_ID=
# GOOGLE_SHEET_ROSTER_RANGE=Roster!A:Z
# GOOGLE_SHEETS_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SHEETS_PRIVATE_KEY=
# Public/published CSV URLs are supported only for tokenless rosters.
# GOOGLE_SHEET_ROSTER_CSV_URL=

# --- Phase 2 GHL health checks ---
GHL_TOKEN_HEALTH_CRON=15 13 * * *
# GHL_PIPELINE_SNAPSHOT_CRON=0 14 * * 1
# GHL_CONFIG_INVENTORY_CRON=0 15 1 * *

# --- Phase 3 Assistable OAuth health ---
# ASSISTABLE_API_KEY=
# ASSISTABLE_API_BASE_URL=https://api.assistable.ai
# ASSISTABLE_API_TIMEOUT_MS=15000
# ASSISTABLE_OAUTH_HEALTH_CRON=30 13 * * *

# --- Phase 3 n8n workflow health ---
# N8N_API_KEY=
# N8N_API_BASE_URL=https://n8n.voyze.ai
# N8N_API_TIMEOUT_MS=15000
# N8N_STALE_EXECUTION_HOURS=24
# N8N_WORKFLOW_HEALTH_CRON=45 13 * * *
# Unified daily fleet health (default enabled; replaces separate GHL/Assistable/n8n alert crons)
# FLEET_DAILY_HEALTH_ENABLED=true
# FLEET_DAILY_HEALTH_CRON=0 14 * * *
# GHL_API_BASE_URL=https://services.leadconnectorhq.com
# GHL_API_VERSION=2021-07-28
# GHL_API_TIMEOUT_MS=15000
