# ops-manager production environment
# Rendered by scripts/scaffold-env.sh into /opt/ops-manager/.env (0600 root:root). Never commit the rendered .env.

# --- Node / app ---
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
APP_VERSION=0.1.0

# --- Postgres passwords (REQUIRED; docker-compose substitutes these) ---
# Rendered from: openssl rand -base64 32, mapped to base64url so they stay URL-safe
# inside the postgres:// strings docker-compose builds from them.
POSTGRES_ADMIN_PASSWORD=__GEN_POSTGRES_ADMIN_PASSWORD__
POSTGRES_APP_PASSWORD=__GEN_POSTGRES_APP_PASSWORD__
# DATABASE_URL / DATABASE_ADMIN_URL are intentionally NOT set here:
# docker-compose builds them from the two passwords above and injects them.

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- LiteLLM ---
LITELLM_PROXY_URL=http://litellm:4000
LITELLM_MASTER_KEY=__GEN_LITELLM_MASTER_KEY__
# PLACEHOLDER: real Anthropic API key (LiteLLM uses it to call Anthropic).
ANTHROPIC_API_KEY=REPLACE_ME_ANTHROPIC_API_KEY

# --- Slack (Socket Mode) ---
SLACK_BOT_TOKEN=REPLACE_ME_SLACK_BOT_TOKEN
SLACK_SIGNING_SECRET=REPLACE_ME_SLACK_SIGNING_SECRET
SLACK_APP_TOKEN=REPLACE_ME_SLACK_APP_TOKEN
SLACK_ALERTS_CHANNEL=#ops-manager-alerts

# --- Approval gate ---
BYPASS_APPROVAL=true

