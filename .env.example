# Node
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Postgres passwords — REQUIRED. docker-compose injects POSTGRES_ADMIN_PASSWORD into
# the postgres container (POSTGRES_PASSWORD for role 'ops') and builds the app's
# DATABASE_URL / DATABASE_ADMIN_URL from these at startup. No defaults: if either is
# unset the stack fails to start (so prod never silently boots with a dev password).
# These must match the passwords embedded in the URLs below.
POSTGRES_ADMIN_PASSWORD=dev_admin_password
POSTGRES_APP_PASSWORD=dev_password

# Postgres (app role — limited permissions on audit_log)
DATABASE_URL=postgres://ops_app:dev_password@postgres:5432/opsmanager
# Admin role for migrations (CREATE ROLE, GRANT, etc.)
DATABASE_ADMIN_URL=postgres://ops:dev_admin_password@postgres:5432/opsmanager

# Redis
REDIS_URL=redis://redis:6379

# LiteLLM
LITELLM_PROXY_URL=http://litellm:4000
LITELLM_MASTER_KEY=dev_master_key_change_in_prod
ANTHROPIC_API_KEY=your_anthropic_key_here

# Slack (Socket Mode for Phase 1)
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=your_signing_secret
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_ALERTS_CHANNEL=#ops-manager-alerts

# Phase 2 — encrypted Postgres secrets store (generate for prod; never commit)
# SECRETS_MASTER_KEY=
# Google Sheet roster source.
# If the Sheet contains PIT tokens, do not publish it or paste its URL into chat.
# Share the private Sheet with a Google service account and configure these values:
# GOOGLE_SHEET_ROSTER_SPREADSHEET_ID=
# GOOGLE_SHEET_ROSTER_RANGE=Roster!A:Z
# GOOGLE_SHEETS_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Public/published CSV URLs are supported only for tokenless rosters.
# GOOGLE_SHEET_ROSTER_CSV_URL=https://docs.google.com/spreadsheets/d/.../export?format=csv&gid=0

# Approval gate (Phase 4)
# Production: omit BYPASS_APPROVAL entirely
# Dev only:
# BYPASS_APPROVAL=true
# SLACK_APPROVALS_CHANNEL=#ops-manager-approvals
# APPROVAL_EXPIRY_HOURS=4

# App
APP_VERSION=0.1.0
# Droplet: map host 3100 -> container PORT (3000)
# Optional: override heartbeat cron in dev (default: 0 * * * *)
# HEARTBEAT_CRON=*/5 * * * *
# Optional: override daily GHL PIT token health cron (default: 15 13 * * *)
# GHL_TOKEN_HEALTH_CRON=15 13 * * *
# Optional: weekly GHL pipeline snapshot (default: Monday 14:00 UTC)
# GHL_PIPELINE_SNAPSHOT_CRON=0 14 * * 1
# Optional: monthly GHL config inventory (default: 1st of month 15:00 UTC)
# GHL_CONFIG_INVENTORY_CRON=0 15 1 * *
# Phase 3 — Assistable OAuth health (required for Assistable checks)
# ASSISTABLE_API_KEY=
# ASSISTABLE_API_BASE_URL=https://api.assistable.ai
# ASSISTABLE_API_TIMEOUT_MS=15000
# ASSISTABLE_OAUTH_HEALTH_CRON=30 13 * * *
# Phase 3 — n8n workflow health (required for n8n checks)
# N8N_API_KEY=
# N8N_API_BASE_URL=https://n8n.voyze.ai
# N8N_API_TIMEOUT_MS=15000
# N8N_STALE_EXECUTION_HOURS=24
# N8N_WORKFLOW_HEALTH_CRON=45 13 * * *
# Unified daily fleet health (default enabled; replaces separate GHL/Assistable/n8n alert crons)
# FLEET_DAILY_HEALTH_ENABLED=true
# FLEET_DAILY_HEALTH_CRON=0 14 * * *

# Phase 5 — Agent roles
# QA_REVIEW_MODEL=ops-claude-sonnet
# QA_REVIEW_MAX_TRANSCRIPT_CHARS=50000
# CLIENT_CHECKIN_MODEL=ops-claude-sonnet
# PROMPT_OPS_MODEL=ops-claude-sonnet
# PROMPT_OPS_MAX_CONTEXT_CHARS=30000
# QA_AUTO_REVIEW_ENABLED=true
# ASSISTABLE_POST_CALL_WEBHOOK_SECRET=
# QA_AUTO_REVIEW_MODEL=ops-claude-haiku
# QA_REVIEW_ESCALATION_MODEL=ops-claude-sonnet
# QA_REVIEW_SAMPLE_RATE=0.015
# QA_REVIEW_MIN_DURATION_SEC=90
# QA_REVIEW_MIN_TRANSCRIPT_CHARS=200
# QA_REVIEW_NEGATIVE_SENTIMENTS=negative
# QA_REVIEW_ALWAYS_TAGS=negative
# QA_REVIEW_SKIP_TAGS=voicemail reached,machine detected,not answered,dial no answer,dial busy,dial failed
# QA_REVIEW_SLACK_ENABLED=false
# QA_REVIEW_SLACK_MODE=escalation
# QA_REVIEW_SLACK_CHANNEL=#ops-manager-alerts
# QA_FLEET_SUMMARY_ENABLED=false
# QA_FLEET_SUMMARY_CRON=0 15 * * *
# QA_FLEET_SUMMARY_HOURS=24
# QA_FLEET_SUMMARY_CHANNEL=#ops-manager-alerts
# CLIENT_CHECKIN_FLEET_SUMMARY_ENABLED=false
# CLIENT_CHECKIN_FLEET_SUMMARY_CRON=30 15 * * *
# CLIENT_CHECKIN_FLEET_SUMMARY_HOURS=168
# CLIENT_CHECKIN_FLEET_SUMMARY_CHANNEL=#ops-manager-alerts
# CLIENT_CHECKIN_FLEET_SWEEP_ENABLED=false
# CLIENT_CHECKIN_FLEET_SWEEP_CRON=0 15 * * *
# CLIENT_CHECKIN_FLEET_SWEEP_MIN_HOURS=24
# CLIENT_CHECKIN_FLEET_SWEEP_CONCURRENCY=3
# CLIENT_CHECKIN_FLEET_SWEEP_INCLUDE_INACTIVE=false
# CLIENT_CHECKIN_FLEET_SWEEP_LIMIT=
# CLIENT_CHECKIN_FLEET_SWEEP_MODEL=
# PROMPT_OPS_FLEET_SUMMARY_ENABLED=false
# PROMPT_OPS_FLEET_SUMMARY_CRON=0 16 * * *
# PROMPT_OPS_FLEET_SUMMARY_HOURS=168
# PROMPT_OPS_FLEET_SUMMARY_CHANNEL=#ops-manager-alerts
# OPS_FLEET_DIGEST_ENABLED=false
# OPS_FLEET_DIGEST_CRON=30 16 * * *
# OPS_FLEET_DIGEST_HOURS=24
# OPS_FLEET_DIGEST_CHANNEL=#ops-manager-alerts
# OPS_ACCOUNT_ATTENTION_RUN_ENABLED=false
# OPS_ACCOUNT_ATTENTION_RUN_CRON=45 16 * * *
# OPS_ACCOUNT_ATTENTION_RUN_HOURS=24
# OPS_ACCOUNT_ATTENTION_RUN_LIMIT=5
# OPS_ACCOUNT_ATTENTION_RUN_MIN_SIGNALS=2
# OPS_ACCOUNT_ATTENTION_RUN_DIGEST_LIMIT=5
# OPS_ACCOUNT_ATTENTION_RUN_CONCURRENCY=3
# OPS_ACCOUNT_ATTENTION_RUN_CHANNEL=#ops-manager-alerts
# Optional: override LeadConnector API settings for tests/staging.
# GHL_API_BASE_URL=https://services.leadconnectorhq.com
# GHL_API_VERSION=2021-07-28
# GHL_API_TIMEOUT_MS=15000
