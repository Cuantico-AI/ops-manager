# Node
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Postgres passwords — REQUIRED. docker-compose injects POSTGRES_ADMIN_PASSWORD into
# the postgres container (POSTGRES_PASSWORD for role 'ops') and builds the app's
# DATABASE_URL / DATABASE_ADMIN_URL from these at startup. No defaults: if either is
# unset the stack fails to start (so prod never silently boots with a dev password).
# These must match the passwords embedded in the URLs below.
POSTGRES_ADMIN_PASSWORD=dev_admin_password
POSTGRES_APP_PASSWORD=dev_password

# Postgres (app role — limited permissions on audit_log)
DATABASE_URL=postgres://ops_app:dev_password@postgres:5432/opsmanager
# Admin role for migrations (CREATE ROLE, GRANT, etc.)
DATABASE_ADMIN_URL=postgres://ops:dev_admin_password@postgres:5432/opsmanager

# Redis
REDIS_URL=redis://redis:6379

# LiteLLM
LITELLM_PROXY_URL=http://litellm:4000
LITELLM_MASTER_KEY=dev_master_key_change_in_prod
ANTHROPIC_API_KEY=your_anthropic_key_here

# Slack (Socket Mode for Phase 1)
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=your_signing_secret
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_ALERTS_CHANNEL=#ops-manager-alerts

# Phase 2 — encrypted Postgres secrets store (generate for prod; never commit)
# SECRETS_MASTER_KEY=
# Google Sheet roster source.
# If the Sheet contains PIT tokens, do not publish it or paste its URL into chat.
# Share the private Sheet with a Google service account and configure these values:
# GOOGLE_SHEET_ROSTER_SPREADSHEET_ID=
# GOOGLE_SHEET_ROSTER_RANGE=Roster!A:Z
# GOOGLE_SHEETS_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Public/published CSV URLs are supported only for tokenless rosters.
# GOOGLE_SHEET_ROSTER_CSV_URL=https://docs.google.com/spreadsheets/d/.../export?format=csv&gid=0

# Approval gate (Phase 4)
BYPASS_APPROVAL=true

# App
APP_VERSION=0.1.0
# Droplet: map host 3100 -> container PORT (3000)
# Optional: override heartbeat cron in dev (default: 0 * * * *)
# HEARTBEAT_CRON=*/5 * * * *
# Optional: override daily GHL PIT token health cron (default: 15 13 * * *)
# GHL_TOKEN_HEALTH_CRON=15 13 * * *
# Optional: weekly GHL pipeline snapshot (default: Monday 14:00 UTC)
# GHL_PIPELINE_SNAPSHOT_CRON=0 14 * * 1
# Optional: override LeadConnector API settings for tests/staging.
# GHL_API_BASE_URL=https://services.leadconnectorhq.com
# GHL_API_VERSION=2021-07-28
# GHL_API_TIMEOUT_MS=15000
