{
  "name": "ops-manager",
  "version": "0.1.0",
  "description": "Cuantico Operations Manager — autonomous fleet operations chassis",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "postinstall": "prisma generate",
    "build:contracts": "npm run build --workspace @cuantico/contracts",
    "dev": "npm run build:contracts && tsx watch src/server.ts",
    "dev:api": "cross-env DASHBOARD_API_ONLY=true npm run dev",
    "build": "npm run build:contracts && tsc",
    "start": "node dist/server.js",
    "test": "npm run build:contracts && vitest run",
    "lint": "eslint src tests",
    "typecheck": "npm run build:contracts && tsc --noEmit",
    "migrate": "tsx src/lib/db/migrate-cli.ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "dev:dashboard": "npm run build:contracts && npm run dev --workspace @cuantico/dashboard"
  },
  "dependencies": {
    "@cuantico/contracts": "*",
    "@slack/bolt": "^4.4.0",
    "@slack/web-api": "^7.9.1",
    "bullmq": "^5.44.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "pg": "^8.13.3",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@prisma/client": "^7.8.0",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "cross-env": "^7.0.3",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "prisma": "^7.8.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^4.1.8"
  }
}
